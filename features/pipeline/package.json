{
  "name": "@goddard-ai/pipeline",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./schema": {
      "types": {
        "source": "./src/schema.ts",
        "default": "./dist/schema.d.mts"
      },
      "bun": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./loader": {
      "types": {
        "source": "./src/loader.ts",
        "default": "./dist/loader.d.mts"
      },
      "bun": "./src/loader.ts",
      "import": "./dist/loader.mjs"
    },
    "./daemon": {
      "types": {
        "source": "./src/daemon.ts",
        "default": "./dist/daemon.d.mts"
      },
      "bun": "./src/daemon.ts",
      "import": "./dist/daemon.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  },
  "dependencies": {
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "yaml": "2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
