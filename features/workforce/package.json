{
  "name": "@goddard-ai/workforce",
  "version": "0.1.0",
  "description": "Experimental workforce feature package for daemon, SDK, and app integration.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./daemon": {
      "types": {
        "source": "./src/daemon.ts",
        "default": "./dist/daemon.d.mts"
      },
      "bun": "./src/daemon.ts",
      "import": "./dist/daemon.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    },
    "./events": {
      "types": {
        "source": "./src/events.ts",
        "default": "./dist/events.d.mts"
      },
      "bun": "./src/events.ts",
      "import": "./dist/events.mjs"
    },
    "./schema": {
      "types": {
        "source": "./src/schema.ts",
        "default": "./dist/schema.d.mts"
      },
      "bun": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./sdk": {
      "types": {
        "source": "./src/sdk.ts",
        "default": "./dist/sdk.d.mts"
      },
      "bun": "./src/sdk.ts",
      "import": "./dist/sdk.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "node -e \"console.log('Skipping @goddard-ai/workforce tests: package is experimental')\""
  },
  "dependencies": {
    "@b9g/async-context": "catalog:",
    "@agentclientprotocol/sdk": "catalog:",
    "@goddard-ai/config": "workspace:*",
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/libgit2": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/sdk-plugin": "workspace:*",
    "@goddard-ai/session": "workspace:*",
    "kindstore": "catalog:",
    "radashi": "catalog:",
    "ulid": "^3.0.2",
    "zod": "catalog:"
  }
}
