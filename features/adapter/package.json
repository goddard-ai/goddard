{
  "name": "@goddard-ai/adapter",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./catalog": {
      "types": {
        "source": "./src/catalog.ts",
        "default": "./dist/catalog.d.mts"
      },
      "bun": "./src/catalog.ts",
      "import": "./dist/catalog.mjs"
    },
    "./daemon": {
      "types": {
        "source": "./src/daemon.ts",
        "default": "./dist/daemon.d.mts"
      },
      "bun": "./src/daemon.ts",
      "import": "./dist/daemon.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    },
    "./schema": {
      "types": {
        "source": "./src/schema.ts",
        "default": "./dist/schema.d.mts"
      },
      "bun": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./sdk": {
      "types": {
        "source": "./src/sdk.ts",
        "default": "./dist/sdk.d.mts"
      },
      "bun": "./src/sdk.ts",
      "import": "./dist/sdk.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@goddard-ai/config": "workspace:*",
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/managed-agent": "workspace:*",
    "@goddard-ai/paths": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/sdk-plugin": "workspace:*",
    "acp-client": "catalog:",
    "zod": "catalog:"
  }
}
