{
  "name": "@goddard-ai/session",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./daemon": {
      "types": {
        "source": "./src/daemon.ts",
        "default": "./dist/daemon.d.mts"
      },
      "bun": "./src/daemon.ts",
      "import": "./dist/daemon.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    },
    "./events": {
      "types": {
        "source": "./src/events.ts",
        "default": "./dist/events.d.mts"
      },
      "bun": "./src/events.ts",
      "import": "./dist/events.mjs"
    },
    "./schema": {
      "types": {
        "source": "./src/schema.ts",
        "default": "./dist/schema.d.mts"
      },
      "bun": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./sdk": {
      "types": {
        "source": "./src/sdk.ts",
        "default": "./dist/sdk.d.mts"
      },
      "bun": "./src/sdk.ts",
      "import": "./dist/sdk.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.62",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@alloc/tree-kill": "^1.3.0",
    "@b9g/async-context": "catalog:",
    "@goddard-ai/config": "workspace:*",
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/libgit2": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/agent": "workspace:*",
    "@goddard-ai/paths": "workspace:*",
    "@goddard-ai/review-sync": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/sdk-plugin": "workspace:*",
    "@goddard-ai/worktree-plugin": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "acp-client": "catalog:",
    "ai": "^6.0.158",
    "ai-sdk-json-schema": "catalog:",
    "hash-sum": "catalog:",
    "kindstore": "catalog:",
    "kleur": "catalog:",
    "radashi": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/hash-sum": "catalog:"
  }
}
