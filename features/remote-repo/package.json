{
  "name": "@goddard-ai/remote-repo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./backend": {
      "types": {
        "source": "./src/backend.ts",
        "default": "./dist/backend.d.mts"
      },
      "bun": "./src/backend.ts",
      "import": "./dist/backend.mjs"
    },
    "./schema": {
      "types": {
        "source": "./src/schema.ts",
        "default": "./dist/schema.d.mts"
      },
      "bun": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  },
  "dependencies": {
    "@goddard-ai/auth": "workspace:*",
    "@goddard-ai/backend-plugin": "workspace:*",
    "zod": "catalog:"
  }
}
