{
  "name": "@goddard-ai/app",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "scripts": {
    "prepare": "bun run panda:codegen && bun run ./scripts/generate-svg-icon-data.ts",
    "dev": "bun install --frozen-lockfile && bun run ./scripts/dev.ts",
    "build": "bun run panda:codegen && vite build && electrobun build",
    "build:canary": "bun run build --env=canary",
    "build:stable": "bun run build --env=stable",
    "icons:generate": "bun run ./scripts/generate-iconset.ts",
    "panda:codegen": "panda codegen",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "test": "bun test --dots",
    "typecheck": "bun run panda:codegen && tsrx-tsc --noEmit"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@floating-ui/dom": "catalog:",
    "@goddard-ai/daemon-client": "workspace:*",
    "@goddard-ai/inbox": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/paths": "workspace:*",
    "@goddard-ai/pull-request": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/sdk": "workspace:*",
    "@goddard-ai/styled-system": "workspace:*",
    "@goddard-ai/ui-primitives": "workspace:*",
    "@lexical/list": "^0.42.0",
    "@lexical/markdown": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@preact/signals": "catalog:",
    "@preact/signals-core": "^1.14.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@tsrx/preact": "catalog:",
    "@xterm/headless": "^6.0.0",
    "acp-client": "catalog:",
    "bun-pty": "^0.4.8",
    "comark": "0.2.1",
    "culori": "^4.0.2",
    "electrobun": "^1.18.1",
    "fuzzysort2": "^0.1.1",
    "hash-sum": "catalog:",
    "immer": "^11.1.4",
    "lexical": "^0.42.0",
    "lucide-react": "^1.11.0",
    "overlayscrollbars": "^2.16.0",
    "powerkeys": "0.2.1",
    "preact": "catalog:",
    "preact-comark": "0.2.4",
    "preact-in-motion": "^0.2.9",
    "preact-sigma": "6.3.0",
    "radashi": "catalog:",
    "sharp": "^0.34.5",
    "shiki": "4.0.2",
    "tabbable": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@happy-dom/global-registrator": "catalog:",
    "@pandacss/dev": "catalog:",
    "@preact/preset-vite": "^2.10.5",
    "@spiriit/vite-plugin-svg-spritemap": "7.0.0",
    "@tsrx/bun-plugin-preact": "catalog:",
    "@tsrx/vite-plugin-preact": "0.0.41",
    "@types/culori": "^4.0.1",
    "@types/hash-sum": "catalog:",
    "chokidar": "^5.0.0",
    "postcss": "^8.5.10",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "vite": "^8.0.10"
  },
  "overrides": {}
}
