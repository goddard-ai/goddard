{
  "name": "goddard",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "catalog": {
    "@agentclientprotocol/sdk": "^0.22.1",
    "@b9g/async-context": "^0.2.1",
    "@clack/prompts": "^1.3.0",
    "@floating-ui/dom": "^1.7.6",
    "@happy-dom/global-registrator": "^20.9.0",
    "@pandacss/dev": "^1.10.0",
    "@preact/signals": "^2.9.0",
    "@tsrx/bun-plugin-preact": "0.0.51",
    "@tsrx/preact": "0.1.28",
    "@types/hash-sum": "^1.0.2",
    "acp-client": "^0.5.3",
    "ai-sdk-json-schema": "^0.3.1",
    "bun": "1.3.13",
    "cmd-ts": "^0.15.0",
    "hash-sum": "^2.0.0",
    "kindstore": "^0.4.5",
    "kleur": "^4.1.5",
    "mitt": "^3.0.1",
    "preact": "11.0.0-beta.1",
    "radashi": "^12.8.0",
    "rouzer": "^5.2.1",
    "tabbable": "^6.4.0",
    "zod": "^4.3.6"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "precommit:staged-fix": "bun run ./scripts/pre-commit-staged-fix.ts",
    "postcommit:restore-stash": "bun run ./scripts/post-commit-restore-stash.ts",
    "dev": "bun run ./scripts/dev.ts",
    "scaffold:feature": "bun run ./scripts/scaffold-feature-package.ts",
    "build": "turbo run build",
    "fmt": "turbo run fmt",
    "codegen": "turbo run codegen",
    "typecheck": "turbo run typecheck --output-logs=errors-only",
    "lint": "turbo run lint --output-logs=errors-only",
    "test": "bun test scripts/*.test.ts --dots && turbo run test --output-logs=errors-only",
    "smoke:review-sync": "pnpm --dir core/review-sync run smoke",
    "smoke:sprint-branch": "bun run ./core/sprint-branch/scripts/smoke.ts",
    "smoke:workforce": "bun run ./scripts/smoke-workforce.ts",
    "acp": "bun run ./scripts/acp-session.ts",
    "goddard:daemon": "NODE_ENV=development bun run ./scripts/runtime-bun.ts run ./core/daemon/src/main.ts",
    "goddard:logs": "bun run ./core/logs/src/cli.ts",
    "goddard:workforce": "NODE_ENV=development bun run ./workforce/src/main.ts",
    "check:bun-runtime": "bun run ./scripts/check-bun-runtime.ts",
    "check:docs": "bun run ./scripts/check-public-docs.ts",
    "check": "pnpm run check:docs && turbo run codegen && turbo run typecheck lint test --output-logs=errors-only --continue=always"
  },
  "devDependencies": {
    "@clack/prompts": "catalog:",
    "@goddard-ai/review-sync": "workspace:*",
    "@goddard-ai/sprint-branch": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@prettier/plugin-oxc": "^0.1.4",
    "@tsrx/core": "0.1.28",
    "@tsrx/eslint-parser": "0.3.80",
    "@tsrx/eslint-plugin": "0.3.80",
    "@tsrx/prettier-plugin": "0.3.80",
    "@tsrx/typescript-plugin": "0.3.80",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "acp-client": "catalog:",
    "bumped-version": "^0.1.3",
    "bumpp": "^11.1.0",
    "bun": "catalog:",
    "cmd-ts": "catalog:",
    "drizzle-kit": "1.0.0-beta.22-41a7d21",
    "husky": "^9.1.7",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "procband": "^0.3.5",
    "radashi": "catalog:",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "unplugin-raw": "^0.7.0",
    "unplugin-unused": "^0.5.7"
  },
  "packageManager": "pnpm@11.5.1"
}
