{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["bun", "github-actions"],
  "timezone": "America/New_York",
  "schedule": ["* 9 * * 1"],
  "minimumReleaseAge": "14 days",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "ignorePaths": ["app/.agents/skills/**"],
  "packageRules": [
    {
      "description": "Disable minor updates for pre-1.0 dependencies",
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": ["minor"],
      "enabled": false
    },
    {
      "description": "Group Bun minor and patch updates",
      "matchManagers": ["bun"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "bun minor and patch dependencies",
      "groupSlug": "bun-minor-and-patch"
    },
    {
      "description": "Group GitHub Actions minor and patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions minor and patch dependencies",
      "groupSlug": "github-actions-minor-and-patch"
    }
  ]
}
