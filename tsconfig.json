{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "@cloudflare/workers-types"],
    "paths": {
      "@goddard-ai/sdk": ["./sdk/src"],
      "@goddard-ai/schema": ["./core/schema/src"],
      "@goddard-ai/schema/*": ["./core/schema/src/*"],
      "@goddard-ai/storage": ["./core/storage/src"],
      "@goddard-ai/config": ["./core/config/src"],
      "@goddard-ai/loop": ["./core/loop/src"]
    }
  },
  "include": [
    "sdk/raw.d.ts",
    "sdk/src/**/*.ts",
    "sdk/test/**/*.ts",
    "backend/src/**/*.ts",
    "backend/test/**/*.ts",
    "backend/bin/**/*.ts",
    "github-app/src/**/*.ts",
    "github-app/test/**/*.ts",
    "cmd/src/**/*.ts",
    "cmd/test/**/*.ts",
    "cmd/bin/**/*.ts",
    "daemon/src/**/*.ts",
    "daemon/test/**/*.ts",
    "daemon/bin/**/*.ts",
    "core/loop/src/**/*.ts",
    "core/loop/test/**/*.ts",
    "core/schema/src/**/*.ts",
    "core/schema/test/**/*.ts",
    "core/storage/src/**/*.ts",
    "core/storage/test/**/*.ts",
    "core/config/src/**/*.ts",
    "core/config/test/**/*.ts"
  ]
}
