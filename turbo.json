{
  "$schema": "https://v2-9-8.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "codegen": {
      "inputs": [
        "panda.config.ts",
        "src/panda-css/global.css.ts",
        "src/icons/**/*.svg",
        "plugins/svg-icon-build-plugin.ts",
        "plugins/svg-icon-data.template.ts",
        "scripts/generate-svg-icon-data.ts",
        "package.json"
      ],
      "outputs": ["styled-system/**", "src/lib/svg-icon-data.ts"]
    },
    "typecheck": {
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.json",
        "**/tsconfig.json",
        "**/tsdown.config.ts",
        "tsconfig.base.json"
      ],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/oxlintrc.json"
      ],
      "outputs": []
    },
    "test": {
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.json"
      ],
      "outputs": []
    },
    "fmt": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["**/*.json", "**/*.md", "**/*.ts", "**/*.tsrx"]
    }
  }
}
