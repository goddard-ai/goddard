{
  "name": "@goddard-ai/sprint-branch",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "bin": {
    "sprint-branch": "./bin/sprint-branch"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "dev": "bun run ./src/main.ts",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots --timeout=90000"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@goddard-ai/libgit2": "workspace:*",
    "@goddard-ai/review-sync": "workspace:*",
    "cmd-ts": "catalog:",
    "node-notifier": "^10.0.1",
    "radashi": "catalog:",
    "zod": "catalog:"
  }
}
