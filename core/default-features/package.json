{
  "name": "@goddard-ai/default-features",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "exports": {
    "./daemon": {
      "types": {
        "source": "./src/daemon.ts",
        "default": "./dist/daemon.d.mts"
      },
      "bun": "./src/daemon.ts",
      "import": "./dist/daemon.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  },
  "dependencies": {
    "@goddard-ai/action": "workspace:*",
    "@goddard-ai/adapter": "workspace:*",
    "@goddard-ai/auth": "workspace:*",
    "@goddard-ai/creative-weaver": "workspace:*",
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/file-search": "workspace:*",
    "@goddard-ai/inbox": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/loop": "workspace:*",
    "@goddard-ai/pipeline": "workspace:*",
    "@goddard-ai/pull-request": "workspace:*",
    "@goddard-ai/review-session": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/session": "workspace:*",
    "@goddard-ai/workforce": "workspace:*"
  }
}
