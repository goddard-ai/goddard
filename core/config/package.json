{
  "name": "@goddard-ai/config",
  "version": "0.1.0",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node.ts",
        "default": "./dist/node.d.mts"
      },
      "bun": "./src/node.ts",
      "import": "./dist/node.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  },
  "dependencies": {
    "@goddard-ai/schema": "workspace:*"
  }
}
