{
  "name": "@goddard-ai/session",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./src/index.ts"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "types": "./dist/*.d.mts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tree-build && tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/storage": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  }
}
