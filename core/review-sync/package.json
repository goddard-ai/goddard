{
  "name": "@goddard-ai/review-sync",
  "version": "0.1.0",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "bin": {
    "review-sync": "./bin/review-sync"
  },
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "smoke": "bun ./scripts/smoke-happy-path.ts",
    "test": "bun test --dots --timeout=180000 --parallel=4"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@goddard-ai/libgit2": "workspace:*",
    "cmd-ts": "catalog:",
    "radashi": "catalog:"
  }
}
