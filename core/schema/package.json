{
  "name": "@goddard-ai/schema",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "exports": {
    "./*": {
      "types": {
        "source": "./src/*.ts",
        "default": "./dist/*.d.mts"
      },
      "bun": "./src/*.ts",
      "import": "./dist/*.mjs"
    },
    "./json/*": "./json/*"
  },
  "scripts": {
    "prepare": "bun run scripts/generate-acp-adapters.js",
    "build": "tsdown --unused && bun run generate-schemas",
    "generate-schemas": "bun run scripts/generate-json-schemas.ts && prettier -w json/",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "@goddard-ai/ipc": "workspace:^",
    "ai-sdk-json-schema": "catalog:",
    "rouzer": "catalog:",
    "zod": "catalog:"
  }
}
