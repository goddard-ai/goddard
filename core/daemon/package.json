{
  "name": "@goddard-ai/daemon",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "bin": {
    "goddard-daemon": "./dist/main.mjs"
  },
  "type": "module",
  "exports": {
    "./ipc": {
      "types": {
        "source": "./src/ipc.ts",
        "default": "./dist/ipc.d.mts"
      },
      "bun": "./src/ipc.ts",
      "import": "./dist/ipc.mjs"
    }
  },
  "scripts": {
    "dev": "bun --watch run src/main.ts",
    "build": "tsdown --unused && pnpm run generate-schemas",
    "generate-schemas": "bun run scripts/generate-json-schemas.ts && prettier -w ../schema/json/",
    "generate-acp-registry-fallback": "bun scripts/generate-acp-registry-fallback.ts",
    "build:standalone": "bun run ./scripts/build-standalone.ts",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p test --noEmit",
    "test": "bun test --dots --timeout=90000"
  },
  "dependencies": {
    "@goddard-ai/action": "workspace:*",
    "@goddard-ai/auth": "workspace:*",
    "@b9g/async-context": "catalog:",
    "@goddard-ai/backend-plugin": "workspace:*",
    "@goddard-ai/config": "workspace:*",
    "@goddard-ai/daemon-client": "workspace:*",
    "@goddard-ai/daemon-plugin": "workspace:*",
    "@goddard-ai/default-features": "workspace:*",
    "@goddard-ai/inbox": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/managed-agent": "workspace:*",
    "@goddard-ai/logs": "workspace:*",
    "@goddard-ai/loop": "workspace:*",
    "@goddard-ai/paths": "workspace:*",
    "@goddard-ai/pull-request": "workspace:*",
    "@goddard-ai/remote-repo": "workspace:*",
    "@goddard-ai/review-session": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@goddard-ai/session": "workspace:*",
    "@goddard-ai/workforce": "workspace:*",
    "ai-sdk-json-schema": "catalog:",
    "cmd-ts": "catalog:",
    "kindstore": "catalog:",
    "kleur": "catalog:",
    "radashi": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "@goddard-ai/backend": "workspace:*",
    "@goddard-ai/fixtures": "workspace:*",
    "@goddard-ai/worktree-plugin": "workspace:*",
    "@types/hash-sum": "catalog:",
    "hash-sum": "catalog:"
  }
}
