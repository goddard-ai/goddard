{
  "name": "@goddard-ai/daemon-client",
  "version": "0.1.0",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node/index.ts",
        "default": "./dist/node/index.d.mts"
      },
      "bun": "./src/node/index.ts",
      "import": "./dist/node/index.mjs"
    },
    "./browser": {
      "types": {
        "source": "./src/browser/index.ts",
        "default": "./dist/browser/index.d.mts"
      },
      "browser": "./src/browser/index.ts",
      "bun": "./src/browser/index.ts",
      "import": "./dist/browser/index.mjs"
    },
    "./daemon-ipc": {
      "types": {
        "source": "./src/daemon-ipc.ts",
        "default": "./dist/daemon-ipc.d.mts"
      },
      "bun": "./src/daemon-ipc.ts",
      "import": "./dist/daemon-ipc.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p src/node --noEmit && tsgo -p src/browser --noEmit && tsgo -p test --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@goddard-ai/default-features": "workspace:*",
    "@goddard-ai/ipc": "workspace:*",
    "@goddard-ai/paths": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "radashi": "catalog:"
  }
}
