{
  "name": "@goddard-ai/backend",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "bin": {
    "goddard-backend": "./dist/server.mjs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "start": "node dist/server.mjs",
    "build": "tsdown --unused",
    "dev": "wrangler dev",
    "deploy": "alchemy deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@goddard-ai/auth": "workspace:*",
    "@goddard-ai/backend-plugin": "workspace:*",
    "@goddard-ai/default-features": "workspace:*",
    "@goddard-ai/event-filter": "workspace:*",
    "@goddard-ai/github": "workspace:*",
    "@goddard-ai/pull-request": "workspace:*",
    "@goddard-ai/remote-repo": "workspace:*",
    "@goddard-ai/schema": "workspace:*",
    "@hattip/adapter-cloudflare-workers": "^0.0.49",
    "@hattip/adapter-node": "^0.0.49",
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "1.0.0-beta.22-41a7d21",
    "octokit": "^5.0.5",
    "radashi": "catalog:",
    "rouzer": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260425.1",
    "alchemy": "^0.90.1",
    "wrangler": "^4.71.0"
  }
}
