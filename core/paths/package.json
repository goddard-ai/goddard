{
  "name": "@goddard-ai/paths",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node/index.ts",
        "default": "./dist/node/index.d.mts"
      },
      "bun": "./src/node/index.ts",
      "import": "./dist/node/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p src/node --noEmit",
    "test": "bun test --pass-with-no-tests --dots"
  }
}
